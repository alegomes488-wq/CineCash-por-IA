{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "$uid === auth.uid || root.child('config/adminUID').val() === auth.uid"
      }
    },
    "referrals": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null"
      }
    },
    "devices": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null"
      }
    },
    "config": {
      ".read": "true",
      ".write": "root.child('config/adminUID').val() === auth.uid"
    },
    "videos": {
      ".read": "true",
      ".write": "root.child('config/adminUID').val() === auth.uid"
    },
    "withdrawals": {
      ".indexOn": ["uid", "status"],
      ".read": "auth != null",
      "$withdrawalId": {
        ".write": "auth != null && (!data.exists() || root.child('config/adminUID').val() === auth.uid)"
      }
    },
    "security_logs": {
      ".read": "root.child('config/adminUID').val() === auth.uid",
      ".write": "true"
    }
  }
}
