{
  "rules": {
    "config": {
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'alegomes488@gmail.com'"
    },
    "users": {
      ".indexOn": "referralCount",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.email === 'alegomes488@gmail.com')",
        // O usuário NÃO pode mais alterar seu saldo ou vídeos. Só o Admin/Python.
        ".write": "auth != null && auth.token.email === 'alegomes488@gmail.com'",

        "risk_score": { ".write": "auth != null && auth.token.email === 'alegomes488@gmail.com'" }
      }
    },
    "withdrawals": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.email === 'alegomes488@gmail.com')",
        "$wid": {
          // Usuário pode CRIAR um saque, mas nunca EDITAR ou APAGAR um existente
          ".write": "auth != null && auth.uid === $uid && !data.exists()",
          ".validate": "newData.child('status').val() === 'pending'"
        }
      }
    },
    "admin": {
      ".read": "auth != null && auth.token.email === 'alegomes488@gmail.com'",
      ".write": "auth != null && auth.token.email === 'alegomes488@gmail.com'"
    },
    "logs": {
      ".read": "auth != null && auth.token.email === 'alegomes488@gmail.com'",
      ".write": "true"
    }
  }
}
